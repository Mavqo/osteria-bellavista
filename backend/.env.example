# ============================================
# Osteria Bellavista - Environment Configuration
# ============================================

# --------------------------------------------
# Required: Core Application Settings
# --------------------------------------------

# Database path (SQLite)
# For local development: ./osteria.db
# For Railway: /data/osteria.db
DATABASE_PATH=./osteria.db

# Timezone for date validation (default: Europe/Rome)
RESTAURANT_TZ=Europe/Rome

# CORS origin for frontend (required for production)
# Local: http://localhost:3000
# Production: https://your-frontend-domain.com
CORS_ORIGIN=http://localhost:3000

# --------------------------------------------
# Optional: Email Notifications
# --------------------------------------------

# Restaurant email for notifications
RESTAURANT_EMAIL=ristorante@example.com

# SMTP configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# --------------------------------------------
# Optional: Webhook Security
# --------------------------------------------

# Secret key for webhook signature verification (HMAC-SHA256)
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=your-webhook-secret-here

# n8n webhook base URL
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook

# --------------------------------------------
# Optional: LLM Integration (for AI features)
# --------------------------------------------

# OpenAI API key (for GPT-4 customer service)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API key (for Claude booking confirmations)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# --------------------------------------------
# Optional: Admin Settings
# --------------------------------------------

# Admin email for error alerts
ADMIN_EMAIL=admin@example.com

# --------------------------------------------
# Development Only
# --------------------------------------------

# Set to 'true' to enable debug mode
DEBUG=false
